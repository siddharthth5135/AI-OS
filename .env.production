APP_NAME=AI OS
DEBUG=False
VERSION=1.0.0
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres
REDIS_URL=rediss://default:[pass]@[host].upstash.io:6379
SUPABASE_URL=pgvector
SUPABASE_ANON_KEY=6333
CELERY_BROKER_URL=rediss://default:[pass]@[host].upstash.io:6379
CELERY_RESULT_BACKEND=rediss://default:[pass]@[host].upstash.io:6379
CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_TOKENS=2048
DB_POOL_SIZE=10
REDIS_TTL_SECONDS=3600
STORAGE_PATH=/home/appuser/app/storage
# Secrets set separately: GEMINI_API_KEY, JWT_SECRET_KEY, DB_PASSWORD
